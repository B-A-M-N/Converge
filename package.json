{
  "name": "converge",
  "version": "2.0.0",
  "description": "Recurring task engine for CLI AI agents — schedule, enforce stop conditions, and converge on outcomes.",
  "main": "dist/src/daemon/server.js",
  "types": "dist/src/daemon/server.d.ts",
  "bin": {
    "converge": "dist/src/cli/index.js",
    "converge-daemon": "dist/src/cli/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/cli/index.js",
    "daemon": "node dist/src/daemon/server.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:sabotage": "vitest run src/sabotage",
    "test:kill": "vitest run tests/kill",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "commander": "^12.0.0",
    "cron-parser": "^4.9.0",
    "date-fns": "^3.6.0",
    "semver": "^7.7.1",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1"
  },
  "keywords": [
    "loop",
    "schedule",
    "recurring",
    "polling",
    "monitoring",
    "agent",
    "automation"
  ],
  "license": "MIT"
}
